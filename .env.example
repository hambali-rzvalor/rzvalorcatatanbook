# Database Configuration
# Get your connection string from Neon Console: https://console.neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Midtrans QRIS Payment Gateway
# Get your API keys from Midtrans Dashboard: https://dashboard.midtrans.com
# Use Sandbox keys for testing, Production keys for live
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# Application URL (for webhook notifications)
# Use ngrok or similar for local development
APP_URL=http://localhost:3000
